# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tunova_db"
REDIS_URL="redis://localhost:6379"

# Blockchain
ETHEREUM_RPC_URL="https://mainnet.infura.io/v3/YOUR_PROJECT_ID"
POLYGON_RPC_URL="https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID"
BASE_RPC_URL="https://mainnet.base.org"
PRIVATE_KEY="0x..."
CONTRACT_ADDRESSES_TUNE="0x..."
CONTRACT_ADDRESSES_NFT="0x..."

# IPFS
PINATA_API_KEY="your_pinata_api_key"
PINATA_SECRET_KEY="your_pinata_secret_key"

# AI Services
OPENAI_API_KEY="sk-..."
STABILITY_API_KEY="sk-..."
REPLICATE_API_TOKEN="r8_..."

# Audio Services
AWS_S3_BUCKET="tunova-audio"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="us-east-1"

# Social Auth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
TWITTER_API_KEY="your_twitter_api_key"
TWITTER_API_SECRET="your_twitter_api_secret"
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"

# Push Notifications
FCM_SERVER_KEY="your_fcm_server_key"
APNS_KEY_ID="your_apns_key_id"
APNS_TEAM_ID="your_apns_team_id"

# Analytics
MIXPANEL_TOKEN="your_mixpanel_token"
AMPLITUDE_API_KEY="your_amplitude_api_key"

# Security
JWT_SECRET="your_jwt_secret_key"
ENCRYPTION_KEY="your_encryption_key"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# Web3 Configuration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your_walletconnect_project_id"
NEXT_PUBLIC_ALCHEMY_API_KEY="your_alchemy_api_key"

# Feature Flags
NEXT_PUBLIC_ENABLE_MINIGAMES="true"
NEXT_PUBLIC_ENABLE_NFT_MARKETPLACE="true"
NEXT_PUBLIC_ENABLE_MOBILE_APP="true"