# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tunova"

# NextAuth.js
NEXTAUTH_URL="http://localhost:12000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-client-secret"
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Web3
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# Blockchain RPCs
NEXT_PUBLIC_ETHEREUM_RPC_URL="https://mainnet.infura.io/v3/your-key"
NEXT_PUBLIC_POLYGON_RPC_URL="https://polygon-mainnet.infura.io/v3/your-key"
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_ARBITRUM_RPC_URL="https://arb1.arbitrum.io/rpc"

# Smart Contracts
NEXT_PUBLIC_TUNE_TOKEN_ADDRESS="0x..."
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS="0x..."

# IPFS
PINATA_API_KEY="your-pinata-api-key"
PINATA_SECRET_KEY="your-pinata-secret-key"

# AI Services
OPENAI_API_KEY="sk-your-openai-key"
STABILITY_API_KEY="sk-your-stability-key"

# Audio Storage
AWS_S3_BUCKET="tunova-audio"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
MIXPANEL_TOKEN="your-mixpanel-token"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:12000"